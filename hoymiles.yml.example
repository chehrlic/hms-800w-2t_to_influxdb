# Every value can be overridden with an environment variable.
# Use uppercase path segments joined with underscores, e.g.:
# HOST, INTERVAL, LOGGING_LEVEL, SUNSET_DISABLED, INFLUX_URL
# If all required values are provided through env vars, hoymiles.yml is optional.

host: 10.10.100.254
# Shorter intervals break the app.
# https://github.com/suaveolent/hoymiles-wifi/issues/90
interval: 60

logging:
  # DEBUG, INFO, WARNING, ERROR, FATAL
  level: 'INFO'

sunset:
  disabled: false
  latitude: 51.1
  longitude: 10.1
  altitude: 1142

influx:
  url: 'http://<influx_instance>:8086'
  org: '<org>'
  token: '<access_token>'
  bucket: '<bucket>'
  measurement: '<hoymiles>'
